# Database
CONNECT_DB="mongodb://localhost:27017/shoe"

# Client URL (for CORS / redirects)
URL_CLIENT="http://localhost:5173"

# Secret used to sign reset-password JWT. Generate with: openssl rand -hex 32
SECRET_CRYPTO=

# Email (Gmail OAuth2 - used by nodemailer to send OTP, etc.)
EMAIL_USER=
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI="https://developers.google.com/oauthplayground"
REFRESH_TOKEN=

# Groq AI (chatbot)
GROQ_API_KEY=

# MoMo payment gateway
MOMO_PARTNER_CODE="MOMO"
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_REDIRECT_URL="http://localhost:5173/payment/success"
MOMO_IPN_URL="http://localhost:3000/api/payment/momo"

# Node environment: development | production
NODE_ENV="development"
